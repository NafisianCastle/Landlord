# Supabase project settings (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# No Mapbox key needed — maps run on OpenFreeMap (streets) + Esri World
# Imagery (satellite), both free/keyless. See lib/mapStyles.ts.

# SSLCommerz (Merchant Panel > Integration for sandbox store_id/password)
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_IS_SANDBOX=true
# Placeholder — set the real one-time lifetime price (BDT) before launch
LIFETIME_PRICE_BDT=2000
